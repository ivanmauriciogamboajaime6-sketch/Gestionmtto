# Configuración de Seguridad - Variables de Entorno
# Copia este archivo a .env y completa los valores

# Clave secreta para JWT (IMPORTANTE: cambiar en producción)
JWT_SECRET_KEY=tu_clave_secreta_aqui

# URL de la base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/mtto_vehicular

# Habilitar logging de SQL (true/false)
DATABASE_ECHO=false

# Origins permitidos para CORS (separados por coma)
# Ejemplo: http://localhost:8081,https://tu-dominio.com
CORS_ORIGINS=http://localhost:8081

# Configuracion de correo SMTP
# Cambia EMAIL_ENABLED a true cuando ya tengas el SMTP listo
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu_correo@gmail.com
SMTP_PASSWORD=tu_password_o_app_password
EMAIL_FROM=tu_correo@gmail.com
EMAIL_FROM_NAME=MTTO Vehicular
SMTP_USE_TLS=true
SMTP_USE_SSL=false
